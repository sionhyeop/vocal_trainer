{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/coach.js": { "maxDuration": 30 },
    "api/lyrics.js": { "maxDuration": 20 }
  },
  "rewrites": [
    { "source": "/((?!api/|notemaps/|assets/|.*\\.[a-zA-Z0-9]+$).*)", "destination": "/index.html" }
  ]
}
