# 이 파일을 복사해 frontend/.env 로 만들고 값을 채우세요 (.env 는 깃에 안 올라감)
# Vite는 VITE_ 접두사만 클라이언트 번들에 노출함.

# YouTube Data API v3 키 (곡 검색용). Google Cloud Console에서 발급.
# ⚠ 번들에 포함되어 공개됨 → HTTP 리퍼러 제한 권장. 배포 시 Vercel 환경변수로 설정.
VITE_YOUTUBE_API_KEY=

# 가사/추출 백엔드 주소.
# - 정적 배포(데모): 비워두세요 → 가사는 브라우저에서 lrclib 직접 호출,
#   채점은 동봉된 차트곡 캐시(public/notemaps)를 사용. (임의 곡 실시간 추출은 비활성)
# - 로컬 풀기능: http://127.0.0.1:8000
VITE_LYRICS_API=http://127.0.0.1:8000
